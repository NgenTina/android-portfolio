# ──────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.navigation/
captures/
.externalNativeBuild/
.cxx/

# ──────────────────────────────────────────────
# Kotlin
# ──────────────────────────────────────────────
.kotlin/

# ──────────────────────────────────────────────
