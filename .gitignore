# Gradle files
# ──────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# ──────────────────────────────────────────────
# Local configuration file (sdk path, etc)
# ──────────────────────────────────────────────
local.properties

# ──────────────────────────────────────────────
